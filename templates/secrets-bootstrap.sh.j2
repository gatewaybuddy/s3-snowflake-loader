{# ─────────────────────────────────────────────────────────────
   S3 → Snowflake Loader: Secrets Manager Bootstrap
   Parameterized Jinja2 template — rendered by generate.py

   Seeds AWS Secrets Manager with Snowflake credentials
   after CloudFormation creates the secret shells.
   ───────────────────────────────────────────────────────────── #}
#!/bin/bash
# ═══════════════════════════════════════════════════════════════
# Seed Secrets Manager with Snowflake credentials
# Generated at {{ generated_at | default('(manual)') }}
#
# Run AFTER CloudFormation deploys (creates the secret shells).
# This script updates placeholder secrets with real credentials.
# The private keys were generated during setup — DO NOT commit them.
# ═══════════════════════════════════════════════════════════════

set -euo pipefail

AWS_REGION="{{ aws.region }}"

{% for db in databases %}
{%- set db_name = db.name %}
{%- set user = db.service_user %}
{%- set private_key_path = 'output/keys/' ~ user | lower ~ '_private.pem' %}
echo "Updating secret for {{ db_name }}..."
PRIVATE_KEY_{{ loop.index }}=$(cat {{ private_key_path }})

aws secretsmanager update-secret \
  --region "${AWS_REGION}" \
  --secret-id "etl/{{ db_name | lower }}/config" \
  --secret-string "$(cat <<'ENDSECRET'
{
    "snowflake_account": "{{ snowflake.account }}",
    "snowflake_user": "{{ user }}",
    "snowflake_private_key": "${PRIVATE_KEY_{{ loop.index }}}",
    "snowflake_role": "{{ db.role }}",
    "snowflake_warehouse": "{{ snowflake.warehouse }}",
    "snowflake_database": "{{ db_name }}",
    "snowflake_schema": "{{ db.schema }}",
    "snowflake_stage": "{{ naming.stage_name }}",
    "admin_database": "{{ snowflake.admin_database }}",
    "admin_schema": "{{ snowflake.admin_schema }}"
}
ENDSECRET
)"

echo "  Secret etl/{{ db_name | lower }}/config updated."
echo ""

{% endfor %}
echo "All secrets updated."
echo ""
echo "Next steps:"
echo "  1. Run the Snowflake setup SQL (output/snowflake-setup.sql)"
echo "  2. Run DESC INTEGRATION for each integration"
echo "  3. Update CloudFormation parameters with Snowflake IAM ARN + External ID"
echo "  4. Configure S3 event notifications"
